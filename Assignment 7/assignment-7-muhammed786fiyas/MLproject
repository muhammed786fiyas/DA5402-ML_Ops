name: mnist-classifier

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      learning_rate:
        type: float
        default: 0.001
      batch_size:
        type: int
        default: 64
      epochs:
        type: int
        default: 5
    command: "python src/train.py --learning_rate {learning_rate} --batch_size {batch_size} --epochs {epochs}"